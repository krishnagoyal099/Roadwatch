# ─── Application ───────────────────────────────────────────────
APP_NAME=RoadWatch
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=complaint-images

# ─── LLM (Groq) ───────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama3-70b-8192
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.3

# ─── CV Service ────────────────────────────────────────────────
CV_SERVICE_URL=http://localhost:8001       # Internal CV endpoint (or mock)
CV_USE_MOCK=true                           # If true, returns stubbed CV results

# ─── Geocoding ─────────────────────────────────────────────────
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=RoadWatch/1.0

# ─── H3 Spatial ────────────────────────────────────────────────
H3_RESOLUTION=9
H3_K_RING_DISTANCE=1

# ─── Session Store ─────────────────────────────────────────────
SESSION_TTL_MINUTES=30

# ─── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173          # Vite dev server

# ─── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000